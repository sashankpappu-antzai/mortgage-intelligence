# mortgage-intelligence — Environment Configuration
# All defaults point to open-source, self-hosted services.
# No third-party API keys are required to run the system.

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=dev
LOG_LEVEL=INFO

# ── Azure AD (optional - falls back to JWT when not set) ─────────────────────
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_REDIRECT_URI=http://localhost:3100/auth/microsoft/callback

# ── Auth (JWT) ───────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/mortgage_intelligence
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mortgage_intelligence

# ── Encompass (customer's LOS - only when connecting to live instance) ───────
ENCOMPASS_INSTANCE_URL=
ENCOMPASS_CLIENT_ID=
ENCOMPASS_CLIENT_SECRET=
ENCOMPASS_WEBHOOK_SECRET=

# ── Storage (MinIO - open-source S3-compatible, default) ─────────────────────
STORAGE_PROVIDER=s3
STORAGE_BUCKET=mortgage-processor-docs
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT_URL=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin

# ── LLM Provider (Ollama - open-source, local, no API key) ──────────────────
LLM_PROVIDER=ollama
LLM_BASE_URL=http://host.docker.internal:11434
LLM_DEFAULT_MODEL=llama3.1
LLM_VISION_MODEL=llava
LLM_API_KEY=

# ── Langfuse (open-source observability, self-hosted) ────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000

# ── Anthropic / Claude (optional cloud LLM) ─────────────────────────────────
ANTHROPIC_API_KEY=

# ── Azure Blob Storage (optional) ───────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=

# ── ngrok (optional - for webhook testing) ───────────────────────────────────
NGROK_AUTHTOKEN=

# ── DeepEval / Confident AI (optional) ──────────────────────────────────────
DEEPEVAL_API_KEY=

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
