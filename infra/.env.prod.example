# --------------------------------------------------------------------------
# infra/.env.prod — secrets + config for the remote-server deploy.
#
# Copy to .env.prod and fill in the marked values.  Never commit .env.prod.
# --------------------------------------------------------------------------

# ---- Public URLs ---------------------------------------------------------
# After putting nginx/Caddy in front, these are what the browser sees.
# Set to http://<server-ip>:3000 / :8000 only if you are skipping a reverse proxy.
PUBLIC_FRONTEND_URL=https://app.example.com
PUBLIC_BACKEND_URL=https://api.example.com

# Compiled into the frontend image at build time
NEXT_PUBLIC_API_URL=${PUBLIC_BACKEND_URL}

# ---- App ----------------------------------------------------------------
APP_ENV=production
LOG_LEVEL=INFO
TRIAL_MODE=true
# Comma-separated, no wildcard.  Must include the frontend URL exactly.
ALLOWED_ORIGINS=["https://app.example.com"]
SQL_ECHO=false

# ---- Auth ---------------------------------------------------------------
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=__REPLACE_WITH_48_BYTES_OF_RANDOM__

# ---- Postgres -----------------------------------------------------------
# These three feed the compose-managed postgres service.
POSTGRES_USER=mortgage_intelligence
POSTGRES_PASSWORD=__REPLACE_WITH_STRONG_PASSWORD__
POSTGRES_DB=mortgage_intelligence

# The backend reads this — leave as-is when using the bundled postgres.
POSTGRES_URL=postgresql+asyncpg://mortgage_intelligence:${POSTGRES_PASSWORD}@postgres:5432/mortgage_intelligence

# ---- Object storage (Cloudflare R2 recommended) -------------------------
# Create an R2 bucket + S3 API token in the Cloudflare dashboard.
# For an AWS S3 deploy: leave STORAGE_ENDPOINT_URL blank, set STORAGE_REGION
# to your bucket's region (e.g. us-east-1).
STORAGE_PROVIDER=s3
STORAGE_BUCKET=mortgage-intelligence-trial
STORAGE_REGION=auto
STORAGE_ENDPOINT_URL=https://__ACCOUNT_ID__.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=__R2_ACCESS_KEY__
STORAGE_SECRET_KEY=__R2_SECRET_KEY__

# ---- LLM provider -------------------------------------------------------
# 'anthropic'  → cloud, requires ANTHROPIC_API_KEY
# 'ollama'     → self-hosted, requires LLM_BASE_URL pointing at an Ollama install
LLM_PROVIDER=anthropic
LLM_DEFAULT_MODEL=claude-sonnet-4-6
LLM_VISION_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=__YOUR_ANTHROPIC_KEY__

# If you're running Ollama on the same VM, uncomment instead:
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://host.docker.internal:11434
# LLM_DEFAULT_MODEL=llama3.1
# LLM_VISION_MODEL=llava

# ---- Observability (optional) -------------------------------------------
# Self-hosted Langfuse URL + project keys, or Langfuse Cloud.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# ---- Encompass (optional, leave blank for trial) ------------------------
ENCOMPASS_INSTANCE_URL=
ENCOMPASS_CLIENT_ID=
ENCOMPASS_CLIENT_SECRET=
ENCOMPASS_WEBHOOK_SECRET=

# ---- Azure AD (optional, leave blank for trial) -------------------------
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_REDIRECT_URI=
